#!/usr/bin/env bash
# Run a RUFLO hive-mind swarm with an Anthropic API key passed through to the spawned Claude Code
# worker, ON A MODEL YOU CHOOSE. `hive-mind spawn` has no --model flag, so the model is set via the
# ANTHROPIC_MODEL env var that the spawned `claude` reads.
#
# Key resolution (unchanged): ANTHROPIC_API_KEY from the environment or a gitignored ./.env.
#
# Usage:
#   scripts/swarm_migrate.sh "<objective>" [worker_count]
#   scripts/swarm_migrate.sh -m opus "<objective>" [worker_count]
#   MODEL=claude-opus-4-8 scripts/swarm_migrate.sh "<objective>"
#
# Models: sonnet | opus | haiku  (aliases → known ids), or a full id (e.g. claude-opus-4-8 / claude-sonnet-4-6).
set -uo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
RUFLO_VERSION="3.7.0-alpha.8"

MODEL="${MODEL:-}"; OBJECTIVE=""; COUNT=""
while [ $# -gt 0 ]; do
  case "$1" in
    -m|--model) MODEL="${2:-}"; shift 2 ;;
    -h|--help)  sed -n '2,14p' "$0"; exit 0 ;;
    *) if [ -z "$OBJECTIVE" ]; then OBJECTIVE="$1"; elif [ -z "$COUNT" ]; then COUNT="$1"; fi; shift ;;
  esac
done
COUNT="${COUNT:-1}"

if [ -z "$OBJECTIVE" ]; then
  echo "Usage: $0 [-m sonnet|opus|haiku|<id>] \"<objective>\" [worker_count]" >&2
  exit 64
fi

# Resolve the API key: environment first, then ./.env
if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -f ./.env ]; then
  ANTHROPIC_API_KEY="$(grep -E '^ANTHROPIC_API_KEY=' ./.env | head -1 | sed 's/^ANTHROPIC_API_KEY=//; s/["'\'' ]//g')"
fi
if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  echo "ERROR: ANTHROPIC_API_KEY not set (env or ./.env). The spawned worker needs it to authenticate." >&2
  exit 1
fi
export ANTHROPIC_API_KEY

# Model selection → ANTHROPIC_MODEL (the spawned `claude` reads it; spawn has no --model flag).
# Map the three aliases to known ids for reliability; pass any full id straight through.
case "$MODEL" in
  ""|default) : ;;
  opus)   export ANTHROPIC_MODEL="claude-opus-4-8" ;;
  sonnet) export ANTHROPIC_MODEL="claude-sonnet-4-6" ;;
  haiku)  export ANTHROPIC_MODEL="claude-haiku-4-5" ;;
  *)      export ANTHROPIC_MODEL="$MODEL" ;;
esac

echo "▶ hive-mind spawn: $COUNT worker(s), model: ${ANTHROPIC_MODEL:-default}, key ****${ANTHROPIC_API_KEY: -4}"
exec npx -y "ruflo@${RUFLO_VERSION}" hive-mind spawn --claude --non-interactive -n "$COUNT" -o "$OBJECTIVE"
